  "dependencies": {
    "@remotion/cli": "4.0.242",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.242"
  },
  "devDependencies": {
    "@remotion/eslint-config": "4.0.242",
    "@types/react": "18.3.3",
    "@types/web": "0.0.166",
    "eslint": "8.57.0",
    "typescript": "5.4.5"
  }
}