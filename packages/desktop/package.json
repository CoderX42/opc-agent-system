{
  "name": "opc-agent-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "OPC Agent System desktop app (Electron + NestJS + Vue)",
  "main": "src/main.cjs",
  "author": {
    "name": "OPC Agent",
    "email": "dev@opc-agent.example.com"
  },
  "scripts": {
    "dev": "electron .",
    "dev:web": "OPC_DESKTOP_WEB_URL=http://localhost:5173 electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.opc.agent-system",
    "productName": "OPC Agent System",
    "copyright": "Copyright © 2025 OPC Agent",
    "directories": {
      "output": "../../release",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "assets/brand/**/*",
      "package.json",
      "node_modules/**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin"
    ],
    "beforePack": "scripts/prepare-server-runtime.cjs",
    "extraResources": [
      {
        "from": "../web/dist",
        "to": "web"
      },
      {
        "from": ".server-runtime",
        "to": "server"
      }
    ],
    "asar": false,
    "protocols": [
      {
        "name": "OPC Agent",
        "schemes": ["opc-agent"],
        "role": "Viewer"
      }
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "extendInfo": {
        "NSHumanReadableCopyright": "Copyright © 2025 OPC Agent",
        "LSApplicationCategoryType": "public.app-category.business"
      }
    },
    "dmg": {
      "title": "${productName} ${version}",
      "iconSize": 96,
      "contents": [
        { "x": 130, "y": 220, "type": "file" },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ],
      "writeUpdateInfo": true
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "zip", "arch": ["x64"] }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "publisherName": "OPC Agent"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OPC Agent System"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "category": "Office",
      "icon": "assets/icon-1024.png",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "synopsis": "OPC Agent System desktop client",
      "description": "OPC Agent System desktop client with embedded NestJS backend."
    },
    "appImage": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://releases.opc-agent.example.com",
        "channel": "latest",
        "useMultipleRangeRequest": false
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "fs-extra": "^10.1.0",
    "js-yaml": "^4.1.0",
    "lazy-val": "^1.0.5",
    "lodash.escaperegexp": "^4.1.2",
    "lodash.isequal": "^4.5.0",
    "semver": "~7.7.3",
    "tiny-typed-emitter": "^2.1.0",
    "builder-util-runtime": "9.7.0"
  }
}
