# ===========================
# Database Configuration
# ===========================
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=agent-system
DATABASE_USER=agent-system
DATABASE_PASSWORD=change-me
DATABASE_SYNCHRONIZE=false

# ===========================
# Redis Configuration
# ===========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=change-me

# ===========================
# JWT Configuration
# ===========================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
# 勾选"保持登录"时 refresh token 有效期（默认 30 天，不超过 30 天）
JWT_REFRESH_EXPIRES_IN=30d
# 未勾选"保持登录"时 refresh token 有效期（默认 1 天）
JWT_REFRESH_SHORT_EXPIRES_IN=1d
# 密码重置令牌签名密钥（默认基于 JWT_SECRET 派生）
# JWT_RESET_SECRET=

# ===========================
# Mail Configuration
# ===========================
# 未配置时密码重置邮件将以日志形式输出（仅开发环境）
# MAIL_DSN=smtp://user:pass@smtp.example.com:587
# 应用对外可访问的基础地址，用于拼接密码重置链接
APP_BASE_URL=http://localhost:5173

# ===========================
# AI Provider Configuration
# ===========================
# Agent 设置页保存的配置优先级最高；这些变量用于默认兜底。
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ===========================
# Application Configuration
# ===========================
PORT=3000
NODE_ENV=development
