# ===========================
# AI Provider Configuration
# ===========================
DEEPSEEK_API_KEY=your-deepseek-api-key
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ===========================
# Application Configuration
# ===========================
PORT=3000
NODE_ENV=development
