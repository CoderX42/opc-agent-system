# Provider selector: auto, local, openai, flux, sdxl
ASSET_PROVIDER=auto

# Set to true when you want real remote image generation. Without keys, the local
# pixel renderer still generates a complete asset pack.
ENABLE_REMOTE_GENERATION=false

# OpenAI GPT Image API
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=medium

# Flux-compatible endpoint. If your provider supports async jobs, set FLUX_RESULT_URL
# to a URL template such as https://api.example.com/v1/result/{id}.
FLUX_API_KEY=
FLUX_API_URL=https://api.bfl.ai/v1/flux-pro-1.1
FLUX_RESULT_URL=

# SDXL / Stability-compatible endpoint
SDXL_API_KEY=
SDXL_API_URL=https://api.stability.ai/v1/generation/stable-diffusion-xl-1024-v1-0/text-to-image

# Optional local Aseprite binary path. The generator writes command plans even when
# Aseprite is not installed.
ASEPRITE_BIN=aseprite
